# Chain interpolation, edge tessellation, density
# ---------------------------------------------------------------------------

class ChainInterpolationResult:
    """A point interpolated along a shape's chain."""

    @property
    def point(self) -> S2Point: ...
    @property
    def edge_id(self) -> int: ...
    @property
    def distance(self) -> Angle: ...
    def __repr__(self) -> str: ...

class ChainInterpolationQuery:
    """Interpolates points along the edges of a shape (optionally one chain)."""

    def __init__(self, shape: Shape, *, chain_id: int | None = None) -> None: ...
    def get_length(self) -> Angle: ...
    def at_fraction(self, fraction: float) -> ChainInterpolationResult | None: ...
    def at_distance(self, distance: Angle) -> ChainInterpolationResult | None: ...
    def slice(self, begin_fraction: float, end_fraction: float) -> list[S2Point]: ...
    def __repr__(self) -> str: ...

class EdgeTessellator:
    """Approximates spherical edges with planar polylines under a projection."""

    def __init__(
        self,
        projection: PlateCarreeProjection | MercatorProjection,
        tolerance: Angle,
    ) -> None: ...
    def append_projected(self, a: S2Point, b: S2Point) -> list[R2Point]: ...
    def append_unprojected(self, a: R2Point, b: R2Point) -> list[S2Point]: ...
    def __repr__(self) -> str: ...

class S2DensityTree:
    """A hierarchical representation of geometry density by cell."""

    def __init__(self) -> None: ...
    def init_to_vertex_density(
        self, index: ShapeIndex, approximate_size_bytes: int, max_level: int
    ) -> None: ...
    def is_empty(self) -> bool: ...
    def encoded_size(self) -> int: ...
    def __repr__(self) -> str: ...

class DensityClusterQuery:
    """Partitions a density tree into roughly equal-weight CellUnion coverings."""

    def __init__(self, desired_weight: int) -> None: ...
    def coverings(self, density: S2DensityTree) -> list[CellUnion]: ...
    def __repr__(self) -> str: ...
