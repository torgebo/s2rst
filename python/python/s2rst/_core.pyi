    def find_closest_cell(self, target: ShapeTarget | CellUnion) -> CellQueryResult: ...
    def find_closest_cells(
        self,
        target: ShapeTarget | CellUnion,
        *,
        max_results: int = 1,
        max_distance: ChordAngle | None = None,
        max_error: ChordAngle | None = None,
    ) -> list[CellQueryResult]: ...
    def get_distance(self, target: ShapeTarget | CellUnion) -> ChordAngle: ...
    def is_distance_less(
        self, target: ShapeTarget | CellUnion, limit: ChordAngle
    ) -> bool: ...
    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Region algebra
# ---------------------------------------------------------------------------

class PointRegion:
    """A region that contains a single point on the unit sphere."""

    def __init__(self, point: S2Point) -> None: ...
    def point(self) -> S2Point: ...
    def cap_bound(self) -> Cap: ...
    def rect_bound(self) -> Rect: ...
    def cell_union_bound(self) -> list[CellId]: ...
    def contains_point(self, p: S2Point) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...
    def __copy__(self) -> PointRegion: ...
    def __deepcopy__(self, memo: dict) -> PointRegion: ...

class RegionUnion:
    """A union of possibly overlapping regions."""

    def __init__(self) -> None: ...
    def add(self, region: Cap | Rect | CellUnion | PointRegion) -> None: ...
    def is_empty(self) -> bool: ...
    def cap_bound(self) -> Cap: ...
    def rect_bound(self) -> Rect: ...
    def cell_union_bound(self) -> list[CellId]: ...
    def contains_point(self, p: S2Point) -> bool: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...

class RegionIntersection:
    """The intersection of a set of regions (no regions = whole sphere)."""

    def __init__(
        self, regions: list[Cap | Rect | CellUnion | PointRegion] | None = None
    ) -> None: ...
    def cap_bound(self) -> Cap: ...
    def rect_bound(self) -> Rect: ...
    def cell_union_bound(self) -> list[CellId]: ...
    def contains_point(self, p: S2Point) -> bool: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...

