class VertexModel:
    """Boundary semantics for point-in-polygon containment tests.

    - ``OPEN``: boundary points are not contained.
    - ``SEMI_OPEN``: exactly one of each pair of adjacent cells owns a shared
      boundary point (a partition of the sphere has no double-counting).
    - ``CLOSED``: boundary points are contained.
    """

    OPEN: ClassVar["VertexModel"]
    SEMI_OPEN: ClassVar["VertexModel"]
    CLOSED: ClassVar["VertexModel"]

class OpType:
    """The set operation performed by a boolean operation."""

    UNION: ClassVar["OpType"]
    INTERSECTION: ClassVar["OpType"]
    DIFFERENCE: ClassVar["OpType"]
    SYMMETRIC_DIFFERENCE: ClassVar["OpType"]

class PolygonModel:
    """Whether polygon boundaries are treated as part of the interior."""

    OPEN: ClassVar["PolygonModel"]
    SEMI_OPEN: ClassVar["PolygonModel"]
    CLOSED: ClassVar["PolygonModel"]

class PolylineModel:
    """Whether polyline endpoints are treated as part of the polyline."""

    OPEN: ClassVar["PolylineModel"]
    SEMI_OPEN: ClassVar["PolylineModel"]
    CLOSED: ClassVar["PolylineModel"]

