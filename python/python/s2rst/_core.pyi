        self, a: S2Point, b: S2Point, *, cross_type: CrossingType = ...
    ) -> dict[int, list[int]]: ...
    def __repr__(self) -> str: ...

def shape_to_points(shape: Shape) -> list[S2Point]: ...
def find_self_intersection(index: ShapeIndex) -> str | None: ...
def visit_crossing_edge_pairs(
    index: ShapeIndex, *, interior_only: bool = True
) -> list[tuple[int, int, int, int]]: ...

